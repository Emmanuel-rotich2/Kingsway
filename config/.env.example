# Kingsway Academy Environment Configuration
# 
# IMPORTANT: This file contains secrets and should NEVER be committed to git!
# Copy this file to .env and update with your actual credentials

# Environment: development, staging, production
APP_ENV=development

# Debug Mode (true for development, false for production)
DEBUG=true

# Base URL
BASE_URL=http://localhost/Kingsway

# Database Configuration
DB_HOST=127.0.0.1
DB_USER=root
DB_NAME=KingsWayAcademy
DB_PORT=3306
DB_PASS=your_local_db_password

# JWT Configuration (MUST be 64+ random characters in production!)
JWT_SECRET=dev_jwt_secret_change_this_in_production_to_64_chars_minimum
JWT_EXPIRY=3600
JWT_ISSUER=kingsway-prep-school
JWT_AUDIENCE=kingsway-staff

# Email Configuration
SMTP_HOST=mail.kingswaypreparatoryschool.sc.ke
SMTP_PORT=587
SMTP_USERNAME=info@kingswaypreparatoryschool.sc.ke
SMTP_FROM_EMAIL=info@kingswaypreparatoryschool.sc.ke
SMTP_PASSWORD=your_smtp_password_here
SMTP_FROM_NAME=Kingsway Preparatory School

# SMS Configuration (Africa's Talking)
SMS_PROVIDER=africastalking
SMS_API_KEY=your_sms_api_key_here
SMS_USERNAME=sandbox
SMS_APPNAME=Sandbox
SMS_SENDER_ID=Kingsway Preparatory
SMS_SHORTCODE=20174
SMS_WHATSAPP_NUMBER=+254710398690

# M-Pesa Configuration
MPESA_ENVIRONMENT=sandbox
MPESA_CONSUMER_KEY=your_mpesa_consumer_key
MPESA_CONSUMER_SECRET=your_mpesa_consumer_secret
MPESA_SHORTCODE=your_paybill_number
MPESA_PASSKEY=your_mpesa_passkey
MPESA_INITIATOR_NAME=your_initiator_name
MPESA_INITIATOR_PASSWORD=your_initiator_password
MPESA_SECURITY_CREDENTIAL=your_encrypted_security_credential

# KCB Bank Buni Configuration
KCB_ENVIRONMENT=sandbox
KCB_CONSUMER_KEY=your_kcb_consumer_key
KCB_CONSUMER_SECRET=your_kcb_consumer_secret
KCB_API_KEY=your_kcb_api_key
KCB_ORGANIZATION_REFERENCE=your_org_reference
KCB_CREDIT_ACCOUNT=your_kcb_account_number

# Upload paths (leave as 'uploads' for relative, or absolute path for production)
UPLOAD_PATH=uploads

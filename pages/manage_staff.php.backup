<script src="/Kingsway/js/pages/staff_controllers.js"></script>
<script>
    // Set global user role for controller access
    window.currentUserRole = '<?php echo $userRole; ?>';

    document.addEventListener('DOMContentLoaded', function() {
        console.log('[Manage Staff] Initializing controller for role:', window.currentUserRole);
        manageStaffController.init();
        
        // Set today's date as default for employment date
        const empDateEl = document.getElementById('employmentDate');
        if (empDateEl) empDateEl.value = new Date().toISOString().split('T')[0];
    });
</script>
